{
  "name": "atexit.js",
  "version": "1.0.5",
  "description": "Register functions to be called at process termination",
  "keywords": [
    "atexit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BChristieDev/atexit.js.git"
  },
  "license": "MIT",
  "author": {
    "name": "Brandon Christie",
    "email": "bchristie.dev@gmail.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/types/index.d.ts",
  "files": [
    "./dist/**/*",
    "!**/*.tsbuildinfo",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rm -rf dist/",
    "build": "npm run build:cjs && npm run build:esm",
    "postbuild": "printf '{\n  \"type\": \"commonjs\"\n}\n' >dist/cjs/package.json",
    "build:cjs": "npx tsc -p tsconfig.cjs.json",
    "build:esm": "npx tsc -p tsconfig.esm.json",
    "prepublishOnly": "npm run test",
    "test": "node --import tsx --test tests/**/*",
    "preversion": "npm run test",
    "postversion": "git push && git push origin tag v$npm_package_version"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
